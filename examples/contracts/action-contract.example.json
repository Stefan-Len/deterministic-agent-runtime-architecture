{
  "schemaVersion": 1,
  "actionId": "runtime.plan-change-set",
  "title": "Plan Change Set",
  "inputSchema": {
    "type": "object",
    "required": ["requestSummary", "workspaceRef"],
    "properties": {
      "requestSummary": { "type": "string" },
      "workspaceRef": { "type": "string" }

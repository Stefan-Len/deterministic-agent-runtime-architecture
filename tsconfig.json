{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "target": "ES2023",
    "types": ["node"]
  },
  "include": ["runtime-kernel/**/*.ts", "verification-suite/**/*.ts"]
}
